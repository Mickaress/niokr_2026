# Скопируйте в .env и подставьте значения

# --- Django ---
# Локально можно не задавать (по умолчанию режим отладки включён).
DJANGO_DEBUG=0

# Обязательно в проде. Локально можно не задавать — подставится dev-ключ из settings.
DJANGO_SECRET_KEY=сгенерируйте-длинную-случайную-строку

# В проде обязательно: хосты API через запятую (без схемы).
# Локально при DJANGO_DEBUG=1 можно не задавать.
DJANGO_ALLOWED_HOSTS=api.example.com,www.example.com

# --- CORS (фронтенд) ---
# Если не задано — разрешены только http://localhost:5173 и http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- База данных ---
# Если POSTGRES_DB не задан — используется SQLite (db.sqlite3 в корне проекта).
POSTGRES_DB=niokr
POSTGRES_USER=niokr
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Медиафайлы ---
DJANGO_MEDIA_URL=/media/
MEDIA_ROOT=/var/www/niokr/media

# Раздавать uploads через Django при DJANGO_DEBUG=0 (временно; лучше nginx).
DJANGO_SERVE_MEDIA=0

# --- Прод: HTTPS и cookies (актуально при DJANGO_DEBUG=0) ---
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
# Редирект HTTP→HTTPS на уровне Django (часто выключают, если TLS делает прокси)
DJANGO_SECURE_SSL_REDIRECT=0
