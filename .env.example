# Рядом с docker-compose.yml → скопируйте в .env и подставьте свои значения.

# Обязательно при открытии сайта по IP или своему домену (см. текст ошибки DisallowedHost — там ровно тот Host, что нужно добавить).
# Несколько значений через запятую, без пробелов (или с пробелами — settings их обрежет, если там strip; проверьте settings _env_list).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,ВАШ_IP_ИЛИ_ДОМЕН

# Origin браузера для CORS (со схемой и портом, как в адресной строке).
CORS_ALLOWED_ORIGINS=http://ВАШ_IP:8080,http://localhost:8080,http://127.0.0.1:8080
